# Configuración local (sync deshabilitado)

# Cliente: usar proxy para llegar al PLC remoto
USE_MODBUS_PROXY=false
MODBUS_PROXY_HOST=100.101.181.46
MODBUS_PROXY_PORT=1502

# Servidor proxy: activar solo en la maquina que ve el PLC
ENABLE_MODBUS_PROXY_SERVER=false
MODBUS_PROXY_LISTEN_HOST=0.0.0.0
MODBUS_PROXY_LISTEN_PORT=1502
MODBUS_PROXY_TARGET_HOST=192.168.100.64
MODBUS_PROXY_TARGET_PORT=502
